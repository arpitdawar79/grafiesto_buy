# Shared by all storefronts (each app overrides what it needs in apps/<brand>/.env.local)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Per-brand publishable keys (printed by `pnpm seed` in apps/medusa)
MIRAMME_PUBLISHABLE_KEY=pk_xxx
REBRACIEL_PUBLISHABLE_KEY=pk_xxx
SCRABEO_PUBLISHABLE_KEY=pk_xxx
AAMRAH_PUBLISHABLE_KEY=pk_xxx
REBO_PUBLISHABLE_KEY=pk_xxx
