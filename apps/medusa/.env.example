# --- Core ---
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grafiesto
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me
COOKIE_SECRET=replace-me

# --- CORS (comma-separated origins) ---
STORE_CORS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# --- Payments ---
STRIPE_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Storage (S3 / R2 / MinIO) ---
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=grafiesto-media
S3_ENDPOINT=

# --- Email ---
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@grafiesto.com

# --- Admin ---
DISABLE_MEDUSA_ADMIN=false
